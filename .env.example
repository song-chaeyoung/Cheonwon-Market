# Neon Postgres connection string.
# Example: postgres://user:password@host/database?sslmode=require
DATABASE_URL=

# Shared entry code for friends who can access the market.
MARKET_ENTRY_CODE=

# Secret used to sign the access cookie. Use a long random value.
# Generate one with:
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
MARKET_ACCESS_COOKIE_SECRET=

# Vercel Blob read/write token.
BLOB_READ_WRITE_TOKEN=
